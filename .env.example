# Copy to .env and fill in. .env is gitignored.

# API-Football (free tier). Auth header: x-apisports-key
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Reasoning layer: open-source model over an OpenAI-compatible API.
# Default is a local Ollama model (install Ollama, then: `ollama pull llama3.1:8b`).
# To use a hosted OSS provider instead, set REASONER_PROVIDER=openai_compatible and point
# LLM_BASE_URL / LLM_API_KEY / LLM_MODEL at e.g. Groq or OpenRouter.
# Set REASONER_PROVIDER=heuristic to run with no LLM (deterministic baseline-mirroring).
REASONER_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3.5:9b
# Qwen3 thinking mode. Off by default (a single prediction = one stats payload + instructions);
# disabling uses the /no_think soft-switch. 8K max tokens is plenty with thinking off.
LLM_ENABLE_THINKING=false
LLM_MAX_TOKENS=8192

# Competition is fixed for this project: World Cup = league 1, season 2026.
WC_LEAGUE_ID=1
WC_SEASON=2026

# Local SQLite path
DB_PATH=worldcup.db

# Backend the Streamlit frontend talks to
BACKEND_URL=http://localhost:8000

# Free tier = 100 requests/DAY. Identical API-Football calls are cached this long, so any
# given request hits the network at most once per 30 minutes (1800s). Tune down at your own risk.
CACHE_TTL_SECONDS=1800
DAILY_REQUEST_CAP=100
