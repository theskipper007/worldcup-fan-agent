# Copy to .env and fill in. .env is gitignored.

# API-Football (free tier). Auth header: x-apisports-key
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Claude API (tool use). Default to the latest Claude model.
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-opus-4-8

# Competition is fixed for this project: World Cup = league 1, season 2026.
WC_LEAGUE_ID=1
WC_SEASON=2026

# Local SQLite path
DB_PATH=worldcup.db

# Backend the Streamlit frontend talks to
BACKEND_URL=http://localhost:8000
